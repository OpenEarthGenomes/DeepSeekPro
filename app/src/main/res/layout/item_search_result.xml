<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:elevation="2dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <!-- Fájlnév + üzenetszám -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/fileNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📄 beszelgetes.txt"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lineNumberText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 1. üzenet"
                android:textColor="@color/accent"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Szerepkör -->
        <TextView
            android:id="@+id/roleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Felhasználó"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <!-- Tartalom -->
        <TextView
            android:id="@+id/contentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kotlin kódot kérek..."
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

        <!-- Környezet (kontextus) -->
        <TextView
            android:id="@+id/contextText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 ...Kotlin kódot kérek..."
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:background="#F0F0FF"
            android:padding="8dp"
            android:backgroundTint="#F0F0FF" />

        <!-- Találatok száma -->
        <TextView
            android:id="@+id/matchCountText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 3 találat"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
